# Copy this file to .env and fill in your real MySQL credentials.
# .env should NOT be committed to git (it's already covered by .gitignore
# patterns like *.env -- double check yours includes it).

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=CharityAIAgentFullDemoDB

# Optional: point at a completely different database (any SQLAlchemy
# dialect, not just MySQL) by setting a full connection URL here instead.
# If set, this takes precedence over the DB_* vars above.
# Example: DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/mydb
# DATABASE_URL=

# Signs the Flask session cookie for the login system (auth.py / app.py).
# Generate a real one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# If left unset, app.py falls back to a random key on every restart,
# which logs everyone out each time the server restarts.
SECRET_KEY=replace_with_a_random_64_char_hex_string

# Optional: logging verbosity and output shape (see logging_config.py).
# LOG_FORMAT=text is readable in a terminal; LOG_FORMAT=json emits one
# JSON object per line for a log aggregator (CloudWatch, Loki, ELK, ...).
# LOG_LEVEL=INFO
# LOG_FORMAT=text
