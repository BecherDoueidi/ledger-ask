# Copy this file to .env and fill in your real MySQL credentials.
# .env should NOT be committed to git (it's already covered by .gitignore
# patterns like *.env -- double check yours includes it).

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=CharityAIAgentFullDemoDB

# Signs the Flask session cookie for the login system (auth.py / app.py).
# Generate a real one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# If left unset, app.py falls back to a random key on every restart,
# which logs everyone out each time the server restarts.
SECRET_KEY=replace_with_a_random_64_char_hex_string
